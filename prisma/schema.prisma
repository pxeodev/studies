generator client {
  provider = "prisma-client-js"
  previewFeatures = ["relationJoins"]
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Coin {
  id                           String       @id @db.VarChar(255)
  symbol                       String
  name                         String
  categories                   String[]
  coingeckoCategories          String[]
  ath                          Decimal
  atl                          Decimal
  description                  String?
  homepage                     String?
  images                       Json
  twitter                      String?
  circulatingSupply            Decimal
  fullyDilutedValuation        Decimal?
  marketCapRank                Int?
  twitterFollowers             Int?
  marketCap                    BigInt
  tickers                      Json
  totalSupply                  Decimal?
  platforms                    Json?
  defaultPlatform              String?
  dailyChange                  Decimal      @default(0.0)
  weeklyChange                 Decimal      @default(0.0)
  launch_date_end              DateTime?
  launch_date_start            DateTime?
  launch_price                 Decimal?
  launch_roi_btc               Decimal?
  launch_roi_eth               Decimal?
  launch_roi_usd               Decimal?
  derivatives                  Json?
  currentPrice                 Decimal?
  maxSupply                    Decimal?
  lunrAltRank                  Decimal?
  lunrAltRankPrevious          Decimal?
  lunrAverageSentiment         Decimal?
  lunrCategories               String[]
  lunrCurrentPrice             Decimal?
  lunrGalaxyScore              Decimal?
  lunrGalaxyScorePrevious      Decimal?
  lunrInternalId               Int?
  lunrMarketCap                Decimal?
  lunrMarketDominance          Decimal?
  lunrName                     String?
  lunrPercentageChange1h       Decimal?
  lunrPercentageChange24h      Decimal?
  lunrSocialContributors       Int?
  lunrSocialDominance          Decimal?
  lunrSocialScore              Decimal?
  lunrSocialVolume             Decimal?
  lunrSymbol                   String?
  lunrVolume                   Decimal?
  coinpaprikaActive            Boolean?
  coinpaprikaContracts         Json?
  coinpaprikaDescription       String?
  coinpaprikaDevelopmentStatus String?
  coinpaprikaHardwarewallet    Boolean?
  coinpaprikaHashAlgorithm     String?
  coinpaprikaId                String?      @db.VarChar(255)
  coinpaprikaLaunchDateStart   String?
  coinpaprikaLinks             Json?
  coinpaprikaLinksExtended     Json?
  coinpaprikaMessage           String?
  coinpaprikaName              String?
  coinpaprikaOpenSource        Boolean?
  coinpaprikaOrgStructure      String?
  coinpaprikaProofType         String?
  coinpaprikaRank              Int?
  coinpaprikaTeam              Json?
  coinpaprikaWhitepaper        Json?
  coinpaprikaTags              Json?
  coinTimes                    CoinTime[]
  ohlcs                        Ohlc[]
  superTrends                  SuperTrend[]

  @@index([marketCapRank])
}

model Ohlc {
  id          Int      @id @default(autoincrement())
  open        Decimal
  high        Decimal
  low         Decimal
  close       Decimal
  coinId      String   @db.VarChar(255)
  closeTime   DateTime
  quoteSymbol String
  coin        Coin     @relation(fields: [coinId], references: [id])

  @@unique([coinId, quoteSymbol, closeTime])
  @@index([closeTime(sort: Desc)])
  @@index([coinId, quoteSymbol])
}

model CoinTime {
  id        Int      @id @default(autoincrement())
  coinId    String   @db.VarChar(255)
  date      DateTime @db.Date
  marketCap BigInt
  volume    BigInt
  coin      Coin     @relation(fields: [coinId], references: [id])
}

model Exchange {
  id          String  @id @db.VarChar(255)
  name        String
  image       String
  url         String
  centralized Boolean @default(false)
}

model SuperTrend {
  id          Int      @id @default(autoincrement())
  coinId      String   @db.VarChar(255)
  coin        Coin     @relation(fields: [coinId], references: [id])
  quoteSymbol String
  date        DateTime @db.Date
  trend       String
  flavor      String
  weekly      Boolean  @default(false)

  @@unique([coinId, quoteSymbol, date, flavor, weekly])
  @@index([coinId, flavor, weekly, date])
}

model FourHourTrends {
  id         Int       @id @default(autoincrement())
  trend      String
  coinsymbol String    @db.VarChar(255) @default("")
  timestamp  DateTime? @db.Timestamp(6) @default(now())
}

model User {
  id            Int    @id @default(autoincrement())
  walletAddress String @unique
  email         String
}

model WhiteListAddress {
  id            Int    @id @default(autoincrement())
  ip           String @unique
  walletAddress String @unique
}
