// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["extendedIndexes"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Coin {
  id       String   @db.VarChar(255) @id
  symbol     String
  name     String
  categories     String[]
  images Json
  description String
  homepage String
  twitter String
  twitterFollowers Int?
  currentPriceUsd Decimal
  ath Decimal
  atl Decimal
  marketCap BigInt
  marketCapRank Int
  fullyDilutedValuation Decimal?
  circulatingSupply Decimal
  totalSupply Decimal?
  ohlcs Ohlc[]
  tickers Json

  @@index([marketCapRank])
}

model Ohlc {
  id Int @id @default(autoincrement())
  closeTime DateTime
  open Decimal
  high Decimal
  low Decimal
  close Decimal
  coinId String @db.VarChar(255)
  coin Coin @relation(fields: [coinId], references: [id])
  quoteSymbol String

  @@index([coinId, quoteSymbol])
  @@index([closeTime(sort: Desc)])
  @@unique([coinId, quoteSymbol, closeTime])
}