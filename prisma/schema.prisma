// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["extendedIndexes"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Coin {
  id       String   @db.VarChar(255) @id
  symbol     String
  name     String
  categories     String[]
  images Json
  description String?
  homepage String?
  twitter String?
  twitterFollowers Int?
  ath Decimal
  atl Decimal
  marketCap BigInt
  marketCapRank Int
  fullyDilutedValuation Decimal?
  circulatingSupply Decimal
  totalSupply Decimal?
  ohlcs Ohlc[]
  coinTimes CoinTime[]
  tickers Json
  defaultPlatform String?
  platforms Json?
  dailyChange Decimal @default(0.0)
  weeklyChange Decimal @default(0.0)
  launch_price Decimal?
  launch_date_start DateTime?
  launch_date_end DateTime?
  launch_roi_usd Decimal?
  launch_roi_eth Decimal?
  launch_roi_btc Decimal?
  derivatives Json?
  currentPrice Decimal?
  maxSupply Decimal?

  @@index([marketCapRank])
}

model Ohlc {
  id Int @id @default(autoincrement())
  closeTime DateTime
  open Decimal
  high Decimal
  low Decimal
  close Decimal
  coinId String @db.VarChar(255)
  coin Coin @relation(fields: [coinId], references: [id])
  quoteSymbol String

  @@index([coinId, quoteSymbol])
  @@index([closeTime(sort: Desc)])
  @@unique([coinId, quoteSymbol, closeTime])
}

model CoinTime {
  id Int @id @default(autoincrement())
  coinId String @db.VarChar(255)
  coin Coin @relation(fields: [coinId], references: [id])
  date DateTime @db.Date()
  marketCap BigInt
  volume BigInt
}

model Exchange {
  id String @db.VarChar(255) @id
  name String
  image String
  url String
}